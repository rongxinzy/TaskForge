generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedTeams          Team[]          @relation(name: "TeamOwner")
  teamMemberships     TeamMember[]
  projectMemberships  ProjectMember[]
}

model Team {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation(name: "TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  TeamMember[]
  projects Project[]

  @@index([ownerId])
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
  @@index([userId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdBy   String?
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  repositories   Repository[]
  requirements   Requirement[]
  roadmapItems   RoadmapItem[]
  findings       Finding[]
  workItems      WorkItem[]
  runnerProfiles RunnerProfile[] @relation(name: "ProjectRunnerProfiles")
  runnerVisibilities RunnerProjectVisibility[]
  members        ProjectMember[]

  @@index([teamId])
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
  @@index([userId])
}

model Repository {
  id           String  @id @default(cuid())
  projectId    String
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider     String
  url          String
  defaultBranch String?
  externalId   String?
  syncStatus   String  @default("pending")
  lastSyncAt   DateTime?
  syncError    String?

  bindings RepositoryBinding[]
  findings Finding[]
  workItems WorkItem[]
  pullRequests PullRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoadmapItem {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String
  targetDate  DateTime?
  ownerId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Requirement {
  id                 String   @id @default(cuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title              String
  description        String?
  status             String
  priority           String
  acceptanceCriteria String?
  source             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Finding {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  repositoryId String?
  repository  Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  title       String
  description String?
  type        String
  severity    String
  evidenceJson Json?
  status      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkItem {
  id                 String   @id @default(cuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  repositoryId       String?
  repository         Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  type               String
  status             String
  priority           String
  assigneeId         String?
  title              String
  description        String?
  acceptanceCriteria String?
  reproductionSteps  String?

  activeSessionId String?       @unique
  activeSession   AgentSession? @relation(name: "WorkItemActiveSession", fields: [activeSessionId], references: [id])
  sessions        AgentSession[]
  contextBundles  ContextBundle[]
  comments        WorkItemComment[]
  pullRequests    PullRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContextBundle {
  id                  String   @id @default(cuid())
  workItemId          String
  workItem            WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  version             Int
  summary             String?
  goal                String?
  acceptanceCriteria  String?
  sourceRefs          Json?
  relatedFiles        Json?
  history             String?
  recommendedCommands Json?
  promptInput         String?
  tokenEstimate       Int?
  staleAt             DateTime?

  sessions AgentSession[]

  createdAt DateTime @default(now())

  @@unique([workItemId, version])
}

model RunnerProfile {
  id               String    @id @default(cuid())
  ownerId          String
  projectId        String?
  project          Project?  @relation(name: "ProjectRunnerProfiles", fields: [projectId], references: [id], onDelete: SetNull)
  name             String
  status           String
  scope            String    @default("personal")
  adapter          String?
  version          String?
  capabilities     Json?
  lastHeartbeatAt  DateTime?

  bindings     RepositoryBinding[]
  sessions     AgentSession[]
  agents       RunnerAgent[]
  visibilities RunnerProjectVisibility[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RunnerProjectVisibility {
  id        String        @id @default(cuid())
  runnerId  String
  runner    RunnerProfile @relation(fields: [runnerId], references: [id], onDelete: Cascade)
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  visible   Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([runnerId, projectId])
  @@index([projectId])
}

model RunnerAgent {
  id              String        @id @default(cuid())
  runnerId        String
  runner          RunnerProfile @relation(fields: [runnerId], references: [id], onDelete: Cascade)
  name            String
  adapter         String?
  status          String        @default("online")
  lastHeartbeatAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([runnerId, name])
  @@index([runnerId])
}

model RepositoryBinding {
  id           String        @id @default(cuid())
  runnerId     String
  runner       RunnerProfile @relation(fields: [runnerId], references: [id], onDelete: Cascade)
  repositoryId String
  repository   Repository    @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  localPath    String
  remoteUrl    String
  status       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([runnerId, repositoryId])
}

model AgentSession {
  id                 String    @id @default(cuid())
  workItemId         String
  workItem           WorkItem  @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  runnerId           String?
  runner             RunnerProfile? @relation(fields: [runnerId], references: [id], onDelete: SetNull)
  contextBundleId    String?
  contextBundle      ContextBundle? @relation(fields: [contextBundleId], references: [id], onDelete: SetNull)
  mode               String
  status             String
  acpSessionId       String?
  acpAgentInfoJson   Json?
  acpProtocolVersion String?
  startedAt          DateTime?
  completedAt        DateTime?

  activeForWorkItem WorkItem?      @relation(name: "WorkItemActiveSession")
  events            SessionEvent[]
  artifacts         Artifact[]
  pullRequests      PullRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SessionEvent {
  id          String       @id @default(cuid())
  sessionId   String
  session     AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  seq         Int
  type        String
  payload     Json
  rawAcpJson  Json?
  createdAt   DateTime     @default(now())

  @@unique([sessionId, seq])
}

model Artifact {
  id               String       @id @default(cuid())
  sessionId        String
  session          AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type             String
  storageUrl       String
  sha256           String?
  sizeBytes        Int?
  redactionStatus  String       @default("pending")
  metadata         Json?

  createdAt DateTime @default(now())
}

model PromptVersion {
  id        String   @id @default(cuid())
  mode      String
  version   Int
  template  String
  checksum  String
  createdAt DateTime @default(now())

  @@unique([mode, version])
}

model PullRequest {
  id            String     @id @default(cuid())
  workItemId    String
  workItem      WorkItem   @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  sessionId     String?
  session       AgentSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  repositoryId  String
  repository    Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  provider      String
  number        Int?
  externalId    String?
  title         String?
  headBranch    String
  baseBranch    String     @default("main")
  url           String?
  commitSha     String?
  state         String     @default("open")
  createdBy     String     @default("local-agent")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workItemId])
  @@index([sessionId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String
  targetId   String
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
}

model OutboxEvent {
  id           String   @id @default(cuid())
  type         String
  payload      Json
  status       String   @default("pending")
  retryCount   Int      @default(0)
  availableAt  DateTime @default(now())
  createdAt    DateTime @default(now())
}

model WorkItemComment {
  id         String   @id @default(cuid())
  workItemId String
  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  authorId   String?
  body       String
  kind       String   @default("comment")

  createdAt DateTime @default(now())
}
